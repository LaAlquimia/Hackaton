---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const openrouterKey = import.meta.env.PUBLIC_OPENROUTER_API_KEY || '';
---

<Layout title="Chatbot — La Alquimia | Liquid.AI Hackathon" description="Chatbot del equipo La Alquimia para el Liquid.AI Hackathon">
	<!-- Main Container -->
	<main class="content-wrapper chatbot-page">
		<!-- Hero Section -->
		<section class="chatbot-hero">
			<div class="hero-badge glass-card">
				<span class="pulse-dot"></span>
				<span>Chatbot Inteligente • Liquid Glass Interface</span>
			</div>
			
			<h1 class="hero-title">
				Interactúa con Nuestro<br />
				<span class="text-gradient">Chatbot Autónomo</span>
			</h1>
			
			<p class="hero-subtitle">
				Prueba nuestro agente conversacional en tiempo real. Haz preguntas sobre el proyecto, el equipo o el Liquid.AI Hackathon.
			</p>
		</section>

		<!-- Chatbot Interface -->
		<section class="chatbot-section">
			<div id="config" style="display:none">{openrouterKey}</div>
			<div class="chatbot-container glass-card">
				<div class="chatbot-header">
					<div class="chatbot-avatar">
						<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2a2 2 0 0 1 2 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 0 1 7 7h1a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-1v1a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-1H2a1 1 0 0 1-1-1v-3a1 1 0 0 1 1-1h1a7 7 0 0 1 7-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 0 1 2-2z"/>
							<path d="M9 12h.01"/>
							<path d="M15 12h.01"/>
							<path d="M9 16c.5.34 1 .6 2 .6s1.5-.26 2-.6"/>
						</svg>
					</div>
					<div>
						<h2>Agente La Alquimia</h2>
						<p id="chatbot-status">En línea • Potenciado por OpenRouter</p>
					</div>
				</div>

				<div class="chatbot-messages" id="chatbot-messages">
					<div class="message bot-message">
						<div class="message-bubble">
							¡Hola! Soy el chatbot de La Alquimia. Estoy conectado a OpenRouter con modelos de IA. ¿En qué puedo ayudarte?
						</div>
					</div>
				</div>

				<div class="chatbot-typing" id="chatbot-typing" style="display:none">
					<div class="typing-dot"></div>
					<div class="typing-dot"></div>
					<div class="typing-dot"></div>
				</div>

				<form class="chatbot-input-form" id="chatbot-form">
					<input 
						type="text" 
						id="chatbot-input" 
						class="form-input chatbot-input" 
						placeholder="Escribe tu mensaje..." 
						autocomplete="off"
						required
					/>
					<button type="submit" class="btn btn-primary btn-send" id="btn-send">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<line x1="22" y1="2" x2="11" y2="13"/>
							<polygon points="22 2 15 22 11 13 2 9 22 2"/>
						</svg>
					</button>
				</form>
			</div>
		</section>

		<!-- Quick Actions -->
		<section class="quick-actions">
			<button class="quick-action-btn" data-message="¿Qué es La Alquimia?">
				<span>🔮</span>
				¿Qué es La Alquimia?
			</button>
			<button class="quick-action-btn" data-message="¿Qué están construyendo?">
				<span>🤖</span>
				¿Qué están construyendo?
			</button>
			<button class="quick-action-btn" data-message="¿Qué tecnologías usan?">
				<span>⚡</span>
				¿Qué tecnologías usan?
			</button>
			<button class="quick-action-btn" data-message="¿Cuándo es el hackathon?">
				<span>📅</span>
				¿Cuándo es el hackathon?
			</button>
		</section>

		<!-- API Key Input -->
		<section class="api-key-section">
			<div class="api-key-container glass-card">
				<p>Ingresa tu API Key de OpenRouter para conectar el chatbot:</p>
				<div class="api-key-row">
					<input type="password" id="api-key-input" class="form-input" placeholder="sk-or-v1-..." />
					<button class="btn btn-primary" id="api-key-btn">Conectar</button>
				</div>
				<p class="api-key-hint">Tu clave se almacena solo en esta sesión del navegador. <a href="https://openrouter.ai/keys" target="_blank" rel="noopener noreferrer">Obtén una key gratuita</a></p>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	.chatbot-page {
		padding-top: 8rem;
		padding-bottom: 4rem;
	}

	.chatbot-hero {
		text-align: center;
		max-width: 800px;
		margin: 0 auto 4rem auto;
	}

	.chatbot-section {
		max-width: 900px;
		margin: 0 auto;
	}

	.chatbot-container {
		min-height: 600px;
		display: flex;
		flex-direction: column;
	}

	.chatbot-header {
		display: flex;
		align-items: center;
		gap: 1rem;
		padding: 1.5rem 2rem;
		border-bottom: 1px solid var(--border-glass);
	}

	.chatbot-avatar {
		width: 56px;
		height: 56px;
		border-radius: 18px;
		background: linear-gradient(135deg, rgba(103, 232, 249, 0.15), rgba(34, 211, 238, 0.08));
		border: 1px solid rgba(103, 232, 249, 0.25);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--primary-cyan);
		box-shadow: 0 0 20px rgba(103, 232, 249, 0.1);
	}

	.chatbot-header h2 {
		font-family: var(--font-display);
		font-size: 1.35rem;
		font-weight: 700;
		margin-bottom: 0.25rem;
	}

	.chatbot-header p {
		color: var(--text-secondary);
		font-size: 0.9rem;
	}

	.chatbot-messages {
		flex-grow: 1;
		padding: 2rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow-y: auto;
		max-height: 420px;
	}

	.message {
		display: flex;
	}

	.message.bot-message {
		justify-content: flex-start;
	}

	.message.user-message {
		justify-content: flex-end;
	}

	.message-bubble {
		max-width: 70%;
		padding: 1rem 1.25rem;
		border-radius: 18px;
		line-height: 1.5;
		font-size: 0.95rem;
	}

	.bot-message .message-bubble {
		background: rgba(103, 232, 249, 0.08);
		border: 1px solid rgba(103, 232, 249, 0.15);
		color: var(--text-primary);
		border-bottom-left-radius: 4px;
	}

	.user-message .message-bubble {
		background: linear-gradient(135deg, rgba(103, 232, 249, 0.8), rgba(34, 211, 238, 0.75));
		color: white;
		border-bottom-right-radius: 4px;
	}

	.chatbot-input-form {
		display: flex;
		gap: 1rem;
		padding: 1.5rem 2rem;
		border-top: 1px solid var(--border-glass);
	}

	.chatbot-input {
		flex-grow: 1;
	}

	.btn-send {
		width: 48px;
		height: 48px;
		padding: 0;
		flex-shrink: 0;
	}

	.quick-actions {
		max-width: 900px;
		margin: 2rem auto 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.quick-action-btn {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border-glass);
		border-radius: 14px;
		padding: 1rem 1.25rem;
		color: var(--text-primary);
		font-family: var(--font-sans);
		font-size: 0.95rem;
		font-weight: 500;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-align: left;
	}

	.quick-action-btn span {
		margin-right: 0.5rem;
	}

	.quick-action-btn:hover {
		background: rgba(103, 232, 249, 0.1);
		border-color: rgba(103, 232, 249, 0.25);
		transform: translateY(-2px);
	}

	/* Typing indicator */
	.chatbot-typing {
		display: flex;
		gap: 0.4rem;
		padding: 0.75rem 2rem;
		align-items: center;
	}

	.typing-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--primary-cyan);
		animation: typing-bounce 1.4s infinite ease-in-out;
	}

	.typing-dot:nth-child(2) {
		animation-delay: 0.2s;
	}

	.typing-dot:nth-child(3) {
		animation-delay: 0.4s;
	}

	@keyframes typing-bounce {
		0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
		40% { transform: scale(1); opacity: 1; }
	}

	/* API Key section */
	.api-key-section {
		max-width: 900px;
		margin: 2rem auto 0 auto;
	}

	.api-key-container {
		padding: 1.5rem 2rem;
	}

	.api-key-container p {
		color: var(--text-secondary);
		font-size: 0.9rem;
		margin-bottom: 1rem;
	}

	.api-key-row {
		display: flex;
		gap: 1rem;
	}

	.api-key-row .form-input {
		flex-grow: 1;
	}

	.api-key-hint {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin-top: 0.75rem;
		margin-bottom: 0;
	}

	.api-key-hint a {
		color: var(--primary-cyan);
		text-decoration: none;
	}

	.api-key-hint a:hover {
		text-decoration: underline;
	}

	#api-key-btn {
		flex-shrink: 0;
	}

	.btn-connected {
		background: rgba(34, 197, 94, 0.15) !important;
		border-color: rgba(34, 197, 94, 0.3) !important;
		color: #22c55e !important;
		cursor: default !important;
	}

	.btn-error {
		background: rgba(239, 68, 68, 0.15) !important;
		border-color: rgba(239, 68, 68, 0.3) !important;
		color: #ef4444 !important;
	}

	@media (max-width: 768px) {
		.chatbot-page {
			padding-top: 6rem;
		}

		.chatbot-container {
			min-height: 500px;
		}

		.chatbot-header {
			padding: 1.25rem 1.5rem;
		}

		.chatbot-messages {
			padding: 1.5rem;
			max-height: 350px;
		}

		.chatbot-input-form {
			padding: 1.25rem 1.5rem;
			flex-direction: column;
		}

		.btn-send {
			width: 100%;
		}

		.message-bubble {
			max-width: 85%;
		}

		.quick-actions {
			grid-template-columns: 1fr;
		}
	}
</style>

<script>
	const messagesContainer = document.getElementById('chatbot-messages');
	const form = document.getElementById('chatbot-form');
	const input = document.getElementById('chatbot-input');
	const sendBtn = document.getElementById('btn-send');
	const typingEl = document.getElementById('chatbot-typing');
	const statusEl = document.getElementById('chatbot-status');
	const quickActionBtns = document.querySelectorAll('.quick-action-btn');
	const apiKeyInput = document.getElementById('api-key-input');
	const apiKeyBtn = document.getElementById('api-key-btn');

	const builtInKey = document.getElementById('config')?.textContent?.trim() || '';
	let apiKey = builtInKey || localStorage.getItem('openrouter_key') || '';
	let isProcessing = false;

	// OpenRouter config
	const OPENROUTER_MODEL = 'openai/gpt-4o-mini';
	const SYSTEM_PROMPT = `Eres el chatbot del equipo "La Alquimia" que participa en el Liquid.AI Hackathon 2026.
Información sobre el equipo y proyecto:
- Equipo: La Alquimia
- Evento: Liquid.AI Hackathon 2026 (24-26 Julio)
- Proyecto: Agente autónomo con arquitectura multi-agente e interfaz liquid glass
- Tecnologías: Astro, Bun, CSS glassmorphism, APIs IA, vectores, cloud
- El equipo es multidisciplinario de desarrolladores, diseñadores y entusiastas de IA

Responde en español, sé amable y conciso. Si no sabes algo, dilo honestamente.`;

	function addMessage(message, sender) {
		if (!messagesContainer) return;
		const messageEl = document.createElement('div');
		messageEl.className = 'message ' + sender + '-message';
		const bubble = document.createElement('div');
		bubble.className = 'message-bubble';
		bubble.textContent = message;
		messageEl.appendChild(bubble);
		messagesContainer.appendChild(messageEl);
		messagesContainer.scrollTop = messagesContainer.scrollHeight;
	}

	function setTyping(typing) {
		if (!typingEl) return;
		typingEl.style.display = typing ? 'flex' : 'none';
		if (input) input.disabled = typing;
		if (sendBtn) sendBtn.disabled = typing;
	}

	function setStatus(text, isError) {
		if (statusEl) {
			statusEl.textContent = text;
			statusEl.style.color = isError ? '#ef4444' : '';
		}
	}

	function updateApiKeyUI() {
		if (!apiKeyBtn || !apiKeyInput) return;
		if (apiKey) {
			apiKeyBtn.textContent = '✓ Conectado';
			apiKeyBtn.className = 'btn btn-connected';
			apiKeyInput.value = apiKey;
			apiKeyInput.type = 'password';
			setStatus('En línea • Potenciado por OpenRouter');
		} else {
			apiKeyBtn.textContent = 'Conectar';
			apiKeyBtn.className = 'btn btn-primary';
			apiKeyInput.value = '';
			setStatus('Esperando API Key de OpenRouter...', true);
		}
	}

	async function callOpenRouter(messages) {
		const response = await fetch('https://openrouter.ai/api/v1/chat/completions', {
			method: 'POST',
			headers: {
				'Authorization': 'Bearer ' + apiKey,
				'Content-Type': 'application/json',
				'HTTP-Referer': window.location.origin,
				'X-Title': 'La Alquimia Chatbot',
			},
			body: JSON.stringify({
				model: OPENROUTER_MODEL,
				messages: messages,
				max_tokens: 500,
			}),
		});

		if (!response.ok) {
			const errorText = await response.text();
			let errorMsg = 'Error de conexión';
			try {
				const err = JSON.parse(errorText);
				errorMsg = err.error?.message || err.message || errorMsg;
			} catch {}
			throw new Error(errorMsg);
		}

		const data = await response.json();
		return data.choices[0].message.content;
	}

	async function processUserMessage(message) {
		if (!message.trim() || isProcessing) return;

		isProcessing = true;
		addMessage(message, 'user');
		if (input) input.value = '';
		setTyping(true);

		try {
			if (!apiKey) {
				setTimeout(() => {
					addMessage('Primero conecta una API Key de OpenRouter para usar el chatbot con IA.', 'bot');
					setTyping(false);
					isProcessing = false;
				}, 300);
				return;
			}

			const history = [];
			const botMessages = messagesContainer?.querySelectorAll('.bot-message .message-bubble');
			const userMessages = messagesContainer?.querySelectorAll('.user-message .message-bubble');

			history.push({ role: 'system', content: SYSTEM_PROMPT });

			const allMessages = messagesContainer?.querySelectorAll('.message');
			if (allMessages) {
				for (const msg of allMessages) {
					const bubble = msg.querySelector('.message-bubble');
					if (!bubble) continue;
					const role = msg.classList.contains('user-message') ? 'user' : 'assistant';
					if (role === 'assistant' && history.length === 1) continue;
					history.push({ role, content: bubble.textContent });
				}
			}

			const reply = await callOpenRouter(history);
			setTyping(false);
			addMessage(reply, 'bot');
		} catch (err) {
			setTyping(false);
			setStatus('Error: ' + err.message, true);
			addMessage('Lo siento, hubo un error al conectar con OpenRouter: ' + err.message, 'bot');
		} finally {
			isProcessing = false;
		}
	}

	// Event listeners
	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		if (!input) return;
		processUserMessage(input.value);
	});

	quickActionBtns.forEach((btn) => {
		btn.addEventListener('click', () => {
			const message = btn.getAttribute('data-message');
			if (message) processUserMessage(message);
		});
	});

	apiKeyBtn?.addEventListener('click', () => {
		const key = apiKeyInput?.value.trim();
		if (!key) return;
		apiKey = key;
		localStorage.setItem('openrouter_key', key);
		updateApiKeyUI();
		setStatus('En línea • Potenciado por OpenRouter');
	});

	apiKeyInput?.addEventListener('keydown', (e) => {
		if (e.key === 'Enter') apiKeyBtn?.click();
	});

	// Set UI if key is already available (from build env or localStorage)
	if (apiKey) updateApiKeyUI();
</script>
