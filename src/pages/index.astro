---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Liquid.AI Hackathon - Innovación Inteligente">
	<!-- Main Container -->
	<main class="content-wrapper">
		<!-- Hero Section -->
		<section class="hero-section" id="proyecto">
			<div class="hero-container">
				<div class="hero-badge glass-card">
					<span class="pulse-dot"></span>
					<span>Equipo Participante • Liquid.AI Hackathon 2026</span>
				</div>
				
				<h1 class="hero-title">
					Construyendo el Futuro de los<br />
					<span class="text-gradient">Agentes Autónomos</span>
				</h1>
				
				<p class="hero-subtitle">
					Somos <strong>La Alquimia</strong>, un equipo multidisciplinario que participa en el Liquid.AI Hackathon 
					con un agente automatizado de nueva generación. Nuestra propuesta combina orquestación multi-agente 
					con una interfaz liquid glass fluida, transparente y adaptable.
				</p>

				<div class="hero-actions">
					<a href="#capacidades" class="btn btn-primary btn-lg">
						Conoce el Proyecto
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</a>
					<a href="https://github.com/LaAlquimia" target="_blank" rel="noopener noreferrer" class="btn btn-secondary btn-lg">
						<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
						Ver en GitHub
					</a>
				</div>

				<!-- Countdown Timer -->
				<div class="countdown-container glass-card">
					<div class="countdown-title">HACKATHON COMIENZA EN</div>
					<div class="countdown-grid">
						<div class="countdown-item">
							<span class="countdown-val" id="days">38</span>
							<span class="countdown-label">Días</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="hours">14</span>
							<span class="countdown-label">Horas</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="minutes">45</span>
							<span class="countdown-label">Minutos</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="seconds">22</span>
							<span class="countdown-label">Segundos</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Statistics Section -->
		<section class="stats-section">
			<div class="stats-grid">
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">Multi-Agente</div>
					<div class="stat-label">Arquitectura Orquestada</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">10+</div>
					<div class="stat-label">APIs y Servicios</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">Tiempo Real</div>
					<div class="stat-label">Procesamiento en Vivo</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">100%</div>
					<div class="stat-label">Interfaz Liquid Glass</div>
				</div>
			</div>
		</section>

		<!-- Features / Capacidades Section -->
		<section class="features-section" id="capacidades">
			<div class="section-header">
				<span class="section-tag font-display">Capacidades del Agente</span>
				<h2 class="section-title">¿Qué puede hacer?</h2>
				<p class="section-description">
					Nuestro agente automatizado está diseñado para comprender, razonar y actuar en entornos complejos con una interfaz líquida y transparente.
				</p>
			</div>

			<div class="features-grid">
				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
						</svg>
					</div>
					<h3 class="feature-title">Orquestación Multi-Agente</h3>
					<p class="feature-text">Coordina múltiples sub-agentes especializados que colaboran en paralelo para resolver tareas complejas de forma autónoma.</p>
				</div>

				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="12" r="10"/>
							<polyline points="12 6 12 12 16 14"/>
						</svg>
					</div>
					<h3 class="feature-title">Memoria Contextual</h3>
					<p class="feature-text">Mantiene estado y contexto a lo largo de las interacciones, aprendiendo de cada conversación para ofrecer respuestas más precisas.</p>
				</div>

				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
							<line x1="8" y1="21" x2="16" y2="21"/>
							<line x1="12" y1="17" x2="12" y2="21"/>
						</svg>
					</div>
					<h3 class="feature-title">Interfaz Liquid Glass</h3>
					<p class="feature-text">Experiencia visual fluida con efectos de vidrio líquido, animaciones orgánicas y una estética cyberpunk que se adapta al contexto del usuario.</p>
				</div>
			</div>
		</section>

		<!-- Technology / Arquitectura Section -->
		<section class="tracks-section" id="tecnologia">
			<div class="section-header">
				<span class="section-tag font-display">Arquitectura</span>
				<h2 class="section-title">Nuestra Propuesta Tecnológica</h2>
				<p class="section-description">
					Combinamos tecnologías de vanguardia para construir un agente autónomo robusto, escalable y visualmente innovador.
				</p>
			</div>

			<div class="tracks-grid">
				<div class="track-card glass-card">
					<div class="track-badge">CORE</div>
					<h3 class="track-title">Motor del Agente</h3>
					<p class="track-desc">Núcleo inteligente que orquesta sub-agentes especializados con capacidad de razonamiento, planificación y ejecución autónoma de tareas.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> Razonamiento multi-paso</li>
						<li><span>✓</span> Planificación dinámica</li>
						<li><span>✓</span> Ejecución con herramientas externas</li>
					</ul>
				</div>

				<div class="track-card glass-card">
					<div class="track-badge">INTERFAZ</div>
					<h3 class="track-title">Liquid Glass UI</h3>
					<p class="track-desc">Capa de presentación con efectos glassmorphism dinámicos, animaciones fluidas y una experiencia visual que refleja la temática del vidrio líquido.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> Glassmorphism dinámico</li>
						<li><span>✓</span> Micro-interacciones orgánicas</li>
						<li><span>✓</span> Modo adaptativo claro/oscuro</li>
					</ul>
				</div>

				<div class="track-card glass-card">
					<div class="track-badge">INFRAESTRUCTURA</div>
					<h3 class="track-title">Integración y Despliegue</h3>
					<p class="track-desc">Backend escalable con conexión a APIs externas, base de datos vectorial para memoria persistente y despliegue automatizado en la nube.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> APIs REST y WebSocket</li>
						<li><span>✓</span> Memoria vectorial persistente</li>
						<li><span>✓</span> CI/CD a GitHub Pages</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- Timeline / Roadmap Section -->
		<section class="schedule-section" id="roadmap">
			<div class="section-header">
				<span class="section-tag font-display">Roadmap del Proyecto</span>
				<h2 class="section-title">Nuestra Hoja de Ruta</h2>
				<p class="section-description">
					El camino que recorremos para llevar nuestro agente autónomo del concepto a la realidad.
				</p>
			</div>

			<div class="timeline-container">
				<div class="timeline-line"></div>
				
				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Semana 1 • Kickoff</span>
						<h3 class="timeline-title">Definición del Concepto</h3>
						<p class="timeline-text">Definición del alcance del agente, selección de tecnologías base y diseño de la arquitectura del sistema multi-agente.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Semana 2-3 • Desarrollo</span>
						<h3 class="timeline-title">MVP del Agente</h3>
						<p class="timeline-text">Implementación del núcleo del agente con capacidad de razonamiento básico, integración de APIs y primera versión de la interfaz liquid glass.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Semana 4 • Preparación</span>
						<h3 class="timeline-title">Demo y Testing</h3>
						<p class="timeline-text">Pruebas de integración, refinamiento de la interfaz, preparación de la demo y ensayo del pitch para la presentación final.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">24-26 Julio • Hackathon</span>
						<h3 class="timeline-title">Liquid.AI Hackathon</h3>
						<p class="timeline-text">Presentación final del proyecto, demo en vivo ante los jueces y entrega del repositorio con toda la documentación técnica.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="faq-section" id="faq">
			<div class="section-header">
				<span class="section-tag font-display">Preguntas Frecuentes</span>
				<h2 class="section-title">Sobre el Equipo y el Proyecto</h2>
			</div>

			<div class="faq-grid">
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Quiénes son La Alquimia?</h3>
					<p class="faq-answer">Somos un equipo multidisciplinario de desarrolladores, diseñadores y entusiastas de la IA que participamos en el Liquid.AI Hackathon con un proyecto de agente autónomo.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Qué están construyendo exactamente?</h3>
					<p class="faq-answer">Un agente automatizado con arquitectura multi-agente, capaz de razonar, planificar y ejecutar tareas complejas. Todo envuelto en una interfaz liquid glass de última generación.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Qué tecnologías utilizan?</h3>
					<p class="faq-answer">El proyecto está construido con Astro, Bun, CSS nativo con glassmorphism, y se integra con APIs de IA generativa, bases de datos vectoriales y servicios cloud.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Dónde puedo seguir el proyecto?</h3>
					<p class="faq-answer">Todo el desarrollo es público en nuestro repositorio de GitHub. Puedes seguir nuestro progreso, revisar el código y contribuir con sugerencias.</p>
				</div>
			</div>
		</section>

		<!-- CTA Banner -->
		<section class="cta-banner">
			<div class="cta-card glass-card">
				<h2 class="cta-title">¿Quieres saber más sobre nuestro proyecto?</h2>
				<p class="cta-text">Síguenos en GitHub para no perderte ninguna actualización del desarrollo de nuestro agente autónomo liquid glass.</p>
				<a href="https://github.com/LaAlquimia" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
					Seguir en GitHub
				</a>
			</div>
		</section>
	</main>

	<!-- Contact Modal -->
	<div class="modal-overlay" id="contact-modal">
		<div class="modal-card glass-card">
			<button class="modal-close" aria-label="Cerrar modal">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
			
			<div class="modal-header">
				<h3 class="modal-title font-display text-gradient">Contáctanos</h3>
				<p class="modal-desc">Déjanos tu mensaje y te responderemos a la brevedad.</p>
			</div>

			<form class="modal-form" id="contact-form">
				<div class="form-group">
					<label for="contact-name" class="form-label">Nombre</label>
					<input type="text" id="contact-name" required class="form-input" placeholder="Tu nombre" />
				</div>
				
				<div class="form-group">
					<label for="contact-email" class="form-label">Correo Electrónico</label>
					<input type="email" id="contact-email" required class="form-input" placeholder="tu@email.com" />
				</div>

				<div class="form-group">
					<label for="contact-message" class="form-label">Mensaje</label>
					<textarea id="contact-message" rows="4" class="form-input" placeholder="Cuéntanos sobre tu interés en el proyecto..."></textarea>
				</div>

				<button type="submit" class="btn btn-primary btn-submit">
					Enviar Mensaje
				</button>
			</form>

			<div class="modal-success-state" id="modal-success">
				<div class="success-icon-container">
					<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<polyline points="20 6 9 17 4 12"/>
					</svg>
				</div>
				<h4 class="success-title font-display text-gradient">¡Mensaje Enviado!</h4>
				<p class="success-desc">Gracias por contactarnos. Te responderemos lo antes posible.</p>
				<button class="btn btn-secondary close-success-btn">Cerrar</button>
			</div>
		</div>
	</div>
</Layout>

<style>
	/* Background liquid styling */
	.fluid-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.35;
		mix-blend-mode: screen;
		animation: float-blob 20s infinite alternate ease-in-out;
	}

	.blob-1 {
		top: -10%;
		left: 10%;
		width: 450px;
		height: 450px;
		background: radial-gradient(circle, rgba(103, 232, 249, 0.35) 0%, transparent 70%);
	}

	.blob-2 {
		bottom: 10%;
		right: -5%;
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(34, 211, 238, 0.3) 0%, transparent 70%);
		animation-delay: -5s;
		animation-duration: 25s;
	}

	.blob-3 {
		top: 40%;
		left: 50%;
		width: 350px;
		height: 350px;
		background: radial-gradient(circle, rgba(103, 232, 249, 0.2) 0%, transparent 70%);
		animation-delay: -10s;
	}

	@keyframes float-blob {
		0% {
			transform: translate(0, 0) scale(1);
		}
		50% {
			transform: translate(50px, -60px) scale(1.1);
		}
		100% {
			transform: translate(-30px, 40px) scale(0.95);
		}
	}

	/* Navigation Bar Styling */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgba(7, 11, 19, 0.45);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-glass);
		transition: var(--transition-smooth);
	}

	.navbar-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--text-primary);
		letter-spacing: 1px;
	}

	.text-accent {
		color: var(--primary-cyan);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: var(--transition-smooth);
	}

	.nav-link:hover {
		color: var(--primary-cyan);
		text-shadow: 0 0 10px rgba(103, 232, 249, 0.35);
	}

	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		z-index: 101;
	}

	.mobile-menu-btn span {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--text-primary);
		transition: var(--transition-smooth);
	}

	/* Buttons Styling */
	.btn {
		font-family: var(--font-sans);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		font-weight: 600;
		padding: 0.65rem 1.35rem;
		border-radius: 12px;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		border: 1px solid transparent;
		font-size: 0.9rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--primary-cyan) 0%, var(--primary-blue) 100%);
		color: white;
		box-shadow: 0 4px 15px rgba(103, 232, 249, 0.2);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(103, 232, 249, 0.35);
	}

	.btn-glass {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.15);
		backdrop-filter: blur(8px);
	}

	.btn-glass:hover {
		background: rgba(103, 232, 249, 0.15);
		border-color: var(--primary-cyan);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-primary);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.18);
	}

	.btn-lg {
		padding: 0.95rem 1.85rem;
		font-size: 1rem;
		border-radius: 14px;
	}

	/* Hero Section */
	.content-wrapper {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		flex-grow: 1;
	}

	.hero-section {
		padding-top: 10rem;
		padding-bottom: 5rem;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1.15rem;
		border-radius: 30px;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--primary-cyan);
		margin-bottom: 2rem;
		background: rgba(13, 20, 38, 0.35);
	}

	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--primary-cyan);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--primary-cyan);
		animation: pulse 1.5s infinite;
	}

	@keyframes pulse {
		0% {
			transform: scale(0.9);
