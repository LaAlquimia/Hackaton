---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Liquid.AI Hackathon - Innovación Inteligente">
	<!-- Background Fluid Blobs -->
	<div class="fluid-background">
		<div class="blob blob-1"></div>
		<div class="blob blob-2"></div>
		<div class="blob blob-3"></div>
	</div>

	<!-- Navigation Bar -->
	<header class="navbar">
		<div class="navbar-container">
			<a href="#" class="logo">
				<svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 19.5C7.86 19.5 4.5 16.14 4.5 12C4.5 7.86 7.86 4.5 12 4.5C16.14 4.5 19.5 7.86 19.5 12C19.5 16.14 16.14 19.5 12 19.5Z" fill="url(#liquid-grad)"/>
					<path d="M12 6C8.69 6 6 8.69 6 12C6 14.21 7.2 16.13 9 17.13V15.01C8.1 14.22 7.5 13.07 7.5 11.75C7.5 9.13 9.63 7 12.25 7C14.87 7 17 9.13 17 11.75C17 13.07 16.4 14.22 15.5 15.01V17.13C17.3 16.13 18.5 14.21 18.5 12C18.5 8.69 15.81 6 12 6Z" fill="url(#liquid-grad)"/>
					<path d="M12 10C10.9 10 10 10.9 10 12C10 13.1 10.9 14 12 14C13.1 14 14 13.1 14 12C14 10.9 13.1 10 12 10Z" fill="url(#liquid-grad)"/>
					<defs>
						<linearGradient id="liquid-grad" x1="2" y1="2" x2="22" y2="22" gradientUnits="userSpaceOnUse">
							<stop offset="0%" stop-color="#38bdf8" />
							<stop offset="100%" stop-color="#2563eb" />
						</linearGradient>
					</defs>
				</svg>
				<span class="logo-text">LIQUID<span class="text-accent">.AI</span></span>
			</a>
			
			<nav class="nav-links">
				<a href="#about" class="nav-link">Acerca de</a>
				<a href="#features" class="nav-link">Beneficios</a>
				<a href="#tracks" class="nav-link">Retos</a>
				<a href="#schedule" class="nav-link">Agenda</a>
				<a href="#faq" class="nav-link">FAQ</a>
			</nav>

			<div class="nav-actions">
				<button class="btn btn-primary btn-glass trigger-modal">Registrarse</button>
			</div>

			<button class="mobile-menu-btn" aria-label="Abrir menú">
				<span></span>
				<span></span>
				<span></span>
			</button>
		</div>
	</header>

	<!-- Main Container -->
	<main class="content-wrapper">
		<!-- Hero Section -->
		<section class="hero-section">
			<div class="hero-container">
				<div class="hero-badge glass-card">
					<span class="pulse-dot"></span>
					<span>Hackaton Global Virtual • 24-26 de Julio, 2026</span>
				</div>
				
				<h1 class="hero-title">
					Crea Inteligencia en un Entorno <br />
					<span class="text-gradient">Liquid Glass</span>
				</h1>
				
				<p class="hero-subtitle">
					Diseña, codifica y despliega la próxima generación de aplicaciones inteligentes en un sprint de 48 horas. Conéctate con mentores líderes y compite por una bolsa de $15,000 USD.
				</p>

				<div class="hero-actions">
					<button class="btn btn-primary btn-lg trigger-modal">
						Unirse a la Hackaton
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M5 12h14M12 5l7 7-7 7"/>
						</svg>
					</button>
					<a href="#tracks" class="btn btn-secondary btn-lg">
						Explorar Retos
					</a>
				</div>

				<!-- Countdown Timer -->
				<div class="countdown-container glass-card">
					<div class="countdown-title">EL REGISTRO CIERRA EN</div>
					<div class="countdown-grid">
						<div class="countdown-item">
							<span class="countdown-val" id="days">38</span>
							<span class="countdown-label">Días</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="hours">14</span>
							<span class="countdown-label">Horas</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="minutes">45</span>
							<span class="countdown-label">Minutos</span>
						</div>
						<div class="countdown-divider">:</div>
						<div class="countdown-item">
							<span class="countdown-val" id="seconds">22</span>
							<span class="countdown-label">Segundos</span>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Statistics Section -->
		<section class="stats-section" id="about">
			<div class="stats-grid">
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">$15,000+</div>
					<div class="stat-label">En Premios en Efectivo</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">48 Hrs</div>
					<div class="stat-label">De Co-creación y Hacking</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">500+</div>
					<div class="stat-label">Hackers Conectados</div>
				</div>
				<div class="stat-card glass-card">
					<div class="stat-value text-gradient">20+</div>
					<div class="stat-label">Expertos y Mentores</div>
				</div>
			</div>
		</section>

		<!-- Features/Benefits Section -->
		<section class="features-section" id="features">
			<div class="section-header">
				<span class="section-tag font-display">Beneficios del Evento</span>
				<h2 class="section-title">¿Por qué deberías participar?</h2>
				<p class="section-description">
					Te ofrecemos un entorno digital diseñado para potenciar tu creatividad técnica y facilitar la creación de redes.
				</p>
			</div>

			<div class="features-grid">
				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
						</svg>
					</div>
					<h3 class="feature-title">Acceso a APIs Premium</h3>
					<p class="feature-text">Créditos gratuitos para modelos de lenguaje avanzados, herramientas de IA generativa y plataformas de despliegue en la nube.</p>
				</div>

				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
						</svg>
					</div>
					<h3 class="feature-title">Mentoría en Vivo</h3>
					<p class="feature-text">Canales dedicados con ingenieros de software, diseñadores UX y especialistas en IA listos para resolver dudas técnicas.</p>
				</div>

				<div class="feature-card glass-card">
					<div class="feature-icon">
						<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<circle cx="12" cy="8" r="7"/>
							<polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/>
						</svg>
					</div>
					<h3 class="feature-title">Certificación Oficial</h3>
					<p class="feature-text">Todas las entregas válidas recibirán una insignia digital certificada respaldada por nuestros patrocinadores.</p>
				</div>
			</div>
		</section>

		<!-- Tracks/Challenges Section -->
		<section class="tracks-section" id="tracks">
			<div class="section-header">
				<span class="section-tag font-display">Categorías de Participación</span>
				<h2 class="section-title">Encuentra tu Categoría</h2>
				<p class="section-description">
					Elige el track que mejor se alinee con tus habilidades. Puedes participar en cualquier categoría con soluciones impulsadas por IA.
				</p>
			</div>

			<div class="tracks-grid">
				<div class="track-card glass-card">
					<div class="track-badge">AGENTES</div>
					<h3 class="track-title">Agentes Autónomos</h3>
					<p class="track-desc">Construye sistemas autónomos capaces de razonar, planificar y ejecutar tareas complejas en la web o interfaces locales.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> Integración multi-agente</li>
						<li><span>✓</span> Memoria de largo plazo</li>
						<li><span>✓</span> Interacción con APIs externas</li>
					</ul>
				</div>

				<div class="track-card glass-card">
					<div class="track-badge">INTERFACES</div>
					<h3 class="track-title">Generación de UI & UX</h3>
					<p class="track-desc">Genera interfaces web vivas o herramientas dinámicas que adapten su interfaz gráfica según el comportamiento de la IA.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> Diseño responsivo</li>
						<li><span>✓</span> Micro-interacciones fluidas</li>
						<li><span>✓</span> Temática Liquid Glass integrada</li>
					</ul>
				</div>

				<div class="track-card glass-card">
					<div class="track-badge">PRODUCTIVIDAD</div>
					<h3 class="track-title">Copilotos de Trabajo</h3>
					<p class="track-desc">Desarrolla herramientas que asistan a profesionales en flujos de trabajo de análisis, redacción de código o generación de media.</p>
					<ul class="track-deliverables">
						<li><span>✓</span> Optimización de tareas cotidianas</li>
						<li><span>✓</span> Interfaz conversacional natural</li>
						<li><span>✓</span> Extensiones del navegador o IDEs</li>
					</ul>
				</div>
			</div>
		</section>

		<!-- Timeline / Schedule Section -->
		<section class="schedule-section" id="schedule">
			<div class="section-header">
				<span class="section-tag font-display">Itinerario del Hackathon</span>
				<h2 class="section-title">Cronograma del Evento</h2>
				<p class="section-description">
					Tres días de pura innovación y desarrollo. No te pierdas ninguna de nuestras sesiones clave.
				</p>
			</div>

			<div class="timeline-container">
				<div class="timeline-line"></div>
				
				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Viernes, 24 de Julio • 17:00 (UTC)</span>
						<h3 class="timeline-title">Ceremonia de Apertura</h3>
						<p class="timeline-text">Bienvenida, anuncio oficial de las APIs patrocinadoras, y revelación de los criterios de evaluación finales.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Viernes, 24 de Julio • 18:00 (UTC)</span>
						<h3 class="timeline-title">¡Comienza la Codificación!</h3>
						<p class="timeline-text">Apertura del repositorio de envío y habilitación de los canales de asistencia técnica y mentoría.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Sábado, 25 de Julio • 15:00 (UTC)</span>
						<h3 class="timeline-title">Sesión de Mentoría UX & Tech</h3>
						<p class="timeline-text">Revisión de proyectos intermedia por parte de mentores especializados para guiar la viabilidad del software.</p>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-marker glass-card"></div>
					<div class="timeline-content glass-card">
						<span class="timeline-time">Domingo, 26 de Julio • 18:00 (UTC)</span>
						<h3 class="timeline-title">Cierre de Entregas & Pitches</h3>
						<p class="timeline-text">Hora límite para subir el código y un video de demostración de 3 minutos. Comienza la deliberación.</p>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ Section -->
		<section class="faq-section" id="faq">
			<div class="section-header">
				<span class="section-tag font-display">Preguntas Frecuentes</span>
				<h2 class="section-title">Resuelve tus Dudas</h2>
			</div>

			<div class="faq-grid">
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿El registro tiene algún costo?</h3>
					<p class="faq-answer">No, la participación en Liquid.AI es completamente gratuita. Solo necesitas una cuenta de GitHub para registrarte.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Puedo participar individualmente?</h3>
					<p class="faq-answer">Sí, puedes participar solo o en equipos de hasta 4 integrantes. Te ayudaremos a buscar equipo si no tienes uno.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Qué herramientas de IA puedo usar?</h3>
					<p class="faq-answer">Cualquier API o modelo de IA es válido. Brindaremos accesos premium exclusivos de nuestros patrocinadores.</p>
				</div>
				<div class="faq-card glass-card">
					<h3 class="faq-question">¿Cómo se realiza el despliegue?</h3>
					<p class="faq-answer">Se sugiere que todas las interfaces sean desplegadas en plataformas web públicas para facilitar su testeo directo.</p>
				</div>
			</div>
		</section>

		<!-- CTA Banner -->
		<section class="cta-banner">
			<div class="cta-card glass-card">
				<h2 class="cta-title">¿Listo para cambiar las reglas del juego?</h2>
				<p class="cta-text">Las plazas son limitadas para garantizar la mejor calidad en la mentoría interactiva. Asegura tu lugar.</p>
				<button class="btn btn-primary btn-lg trigger-modal">Registrarme Ahora</button>
			</div>
		</section>
	</main>

	<!-- Footer -->
	<footer class="footer">
		<div class="footer-container">
			<p class="footer-copy">© 2026 Liquid.AI. Todos los derechos reservados.</p>
			<div class="footer-links">
				<a href="#" class="footer-link">Términos</a>
				<a href="#" class="footer-link">Privacidad</a>
				<a href="#" class="footer-link">Código de Conducta</a>
			</div>
		</div>
	</footer>

	<!-- Register Modal -->
	<div class="modal-overlay" id="register-modal">
		<div class="modal-card glass-card">
			<button class="modal-close" aria-label="Cerrar modal">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<line x1="18" y1="6" x2="6" y2="18"/>
					<line x1="6" y1="6" x2="18" y2="18"/>
				</svg>
			</button>
			
			<div class="modal-header">
				<h3 class="modal-title font-display text-gradient">Únete a Liquid.AI</h3>
				<p class="modal-desc">Completa tu registro para participar y recibir tus accesos a las APIs.</p>
			</div>

			<form class="modal-form" id="registration-form">
				<div class="form-group">
					<label for="reg-name" class="form-label">Nombre Completo</label>
					<input type="text" id="reg-name" required class="form-input" placeholder="Ej. Ana Beltrán" />
				</div>
				
				<div class="form-group">
					<label for="reg-email" class="form-label">Correo Electrónico</label>
					<input type="email" id="reg-email" required class="form-input" placeholder="ana@example.com" />
				</div>

				<div class="form-group">
					<label for="reg-github" class="form-label">Usuario de GitHub</label>
					<input type="text" id="reg-github" required class="form-input" placeholder="ej. anabeltran" />
				</div>

				<div class="form-group">
					<label for="reg-track" class="form-label">Track de Interés</label>
					<select id="reg-track" class="form-input">
						<option value="agents">Agentes Autónomos</option>
						<option value="ui">Generación de UI & UX</option>
						<option value="productivity">Copilotos de Trabajo</option>
					</select>
				</div>

				<button type="submit" class="btn btn-primary btn-submit">
					Confirmar Registro
				</button>
			</form>

			<div class="modal-success-state" id="modal-success">
				<div class="success-icon-container">
					<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
						<polyline points="20 6 9 17 4 12"/>
					</svg>
				</div>
				<h4 class="success-title font-display text-gradient">¡Registro Completo!</h4>
				<p class="success-desc">Te hemos enviado un correo de confirmación con las instrucciones para unirte al Discord oficial.</p>
				<button class="btn btn-secondary close-success-btn">Entendido</button>
			</div>
		</div>
	</div>
</Layout>

<style>
	/* Background liquid styling */
	.fluid-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.35;
		mix-blend-mode: screen;
		animation: float-blob 20s infinite alternate ease-in-out;
	}

	.blob-1 {
		top: -10%;
		left: 10%;
		width: 450px;
		height: 450px;
		background: radial-gradient(circle, rgba(56, 189, 248, 0.4) 0%, transparent 70%);
	}

	.blob-2 {
		bottom: 10%;
		right: -5%;
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(37, 99, 235, 0.35) 0%, transparent 70%);
		animation-delay: -5s;
		animation-duration: 25s;
	}

	.blob-3 {
		top: 40%;
		left: 50%;
		width: 350px;
		height: 350px;
		background: radial-gradient(circle, rgba(56, 189, 248, 0.25) 0%, transparent 70%);
		animation-delay: -10s;
	}

	@keyframes float-blob {
		0% {
			transform: translate(0, 0) scale(1);
		}
		50% {
			transform: translate(50px, -60px) scale(1.1);
		}
		100% {
			transform: translate(-30px, 40px) scale(0.95);
		}
	}

	/* Navigation Bar Styling */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgba(7, 11, 19, 0.45);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-glass);
		transition: var(--transition-smooth);
	}

	.navbar-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--text-primary);
		letter-spacing: 1px;
	}

	.text-accent {
		color: var(--primary-cyan);
	}

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: var(--transition-smooth);
	}

	.nav-link:hover {
		color: var(--primary-cyan);
		text-shadow: 0 0 10px rgba(56, 189, 248, 0.35);
	}

	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		z-index: 101;
	}

	.mobile-menu-btn span {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--text-primary);
		transition: var(--transition-smooth);
	}

	/* Buttons Styling */
	.btn {
		font-family: var(--font-sans);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		font-weight: 600;
		padding: 0.65rem 1.35rem;
		border-radius: 12px;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		border: 1px solid transparent;
		font-size: 0.9rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--primary-cyan) 0%, var(--primary-blue) 100%);
		color: white;
		box-shadow: 0 4px 15px rgba(56, 189, 248, 0.2);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(56, 189, 248, 0.35);
	}

	.btn-glass {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.15);
		backdrop-filter: blur(8px);
	}

	.btn-glass:hover {
		background: rgba(56, 189, 248, 0.15);
		border-color: var(--primary-cyan);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-primary);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.18);
	}

	.btn-lg {
		padding: 0.95rem 1.85rem;
		font-size: 1rem;
		border-radius: 14px;
	}

	/* Hero Section */
	.content-wrapper {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		flex-grow: 1;
	}

	.hero-section {
		padding-top: 10rem;
		padding-bottom: 5rem;
		text-align: center;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
