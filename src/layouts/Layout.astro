---
interface Props {
	title: string;
	description?: string;
}

const { 
	title, 
	description = "La Alquimia — equipo participante en Liquid.AI Hackathon. Presentamos nuestro agente autónomo con interfaz liquid glass de nueva generación." 
} = Astro.props;

// Ensure base path is correct for absolute URLs in assets if needed
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta name="twitter:card" content="summary_large_image" />
		
		<!-- Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300..800;1,300..800&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
	</head>
	<body>
		<!-- Background Fluid Blobs -->
		<div class="fluid-background">
			<div class="blob blob-1"></div>
			<div class="blob blob-2"></div>
			<div class="blob blob-3"></div>
		</div>

		<!-- Navigation Bar -->
		<header class="navbar">
			<div class="navbar-container">
				<a href={`${base}/`} class="logo">
					<svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M12 3L3 8l9 5 9-5-9-5z" stroke="url(#alq-grad)" stroke-width="1.5" fill="none"/>
						<path d="M3 16l9 5 9-5" stroke="url(#alq-grad)" stroke-width="1.5" fill="none"/>
						<path d="M3 12l9 5 9-5" stroke="url(#alq-grad)" stroke-width="1.5" fill="none"/>
						<path d="M12 12l-4-2.5M12 12l4-2.5M12 12v5" stroke="url(#alq-grad)" stroke-width="1.5" fill="none"/>
						<defs>
							<linearGradient id="alq-grad" x1="3" y1="3" x2="21" y2="21" gradientUnits="userSpaceOnUse">
								<stop offset="0%" stop-color="#67e8f9" />
								<stop offset="100%" stop-color="#22d3ee" />
							</linearGradient>
						</defs>
					</svg>
					<span class="logo-text">LA <span class="text-accent">ALQUIMIA</span></span>
				</a>
				
				<nav class="nav-links">
					<a href={`${base}/`} class="nav-link">Inicio</a>
					<a href={`${base}/#proyecto`} class="nav-link">El Proyecto</a>
					<a href={`${base}/chatbot/`} class="nav-link">Chatbot</a>
				</nav>

				<button class="mobile-menu-btn" aria-label="Abrir menú">
					<span></span>
					<span></span>
					<span></span>
				</button>
			</div>
		</header>

		<slot />

		<!-- Footer -->
		<footer class="footer">
			<div class="footer-container">
				<p class="footer-copy">© 2026 La Alquimia • Participando en Liquid.AI Hackathon</p>
				<div class="footer-links">
					<a href={`${base}/`} class="footer-link">Inicio</a>
					<a href={`${base}/chatbot/`} class="footer-link">Chatbot</a>
				</div>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
		--font-display: 'Space Grotesk', var(--font-sans);

		/* Light Cyan Blue Liquid Glass Color Palette */
		--bg-dark: #070b13;
		--bg-card: rgba(10, 18, 34, 0.5);
		--bg-card-hover: rgba(16, 28, 52, 0.65);
		
		--border-glass: rgba(255, 255, 255, 0.08);
		--border-glass-hover: rgba(255, 255, 255, 0.18);
		--border-glow: rgba(103, 232, 249, 0.3);
		
		--text-primary: #f8fafc;
		--text-secondary: #94a3b8;
		--text-muted: #64748b;
		
		--primary-cyan: #67e8f9;
		--primary-blue: #22d3ee;
		--primary-glow: rgba(103, 232, 249, 0.4);
		
		--transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
		
		--shadow-glass: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
		--shadow-glow: 0 0 24px 0 rgba(103, 232, 249, 0.15);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
		background-color: var(--bg-dark);
		color: var(--text-primary);
		font-family: var(--font-sans);
		overflow-x: hidden;
	}

	body {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		background: 
			radial-gradient(circle at 15% 25%, rgba(34, 211, 238, 0.12) 0%, transparent 40%),
			radial-gradient(circle at 85% 75%, rgba(103, 232, 249, 0.1) 0%, transparent 45%),
			radial-gradient(circle at 50% 50%, rgba(103, 232, 249, 0.03) 0%, transparent 60%),
			#070b13;
		background-attachment: fixed;
		overflow-x: hidden;
	}

	/* Scrollbar styling */
	::-webkit-scrollbar {
		width: 10px;
	}
	::-webkit-scrollbar-track {
		background: var(--bg-dark);
	}
	::-webkit-scrollbar-thumb {
		background: rgba(255, 255, 255, 0.1);
		border-radius: 5px;
		border: 2px solid var(--bg-dark);
	}
	::-webkit-scrollbar-thumb:hover {
		background: rgba(103, 232, 249, 0.3);
	}

	/* Liquid Glass effects utilities */
	.glass-card {
		background: var(--bg-card);
		backdrop-filter: blur(16px) saturate(140%);
		-webkit-backdrop-filter: blur(16px) saturate(140%);
		border: 1px solid var(--border-glass);
		border-radius: 20px;
		box-shadow: var(--shadow-glass);
		transition: var(--transition-smooth);
		position: relative;
		overflow: hidden;
	}

	.glass-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: -50%;
		width: 200%;
		height: 100%;
		background: linear-gradient(
			90deg,
			transparent,
			rgba(255, 255, 255, 0.03) 30%,
			rgba(255, 255, 255, 0.08) 50%,
			rgba(255, 255, 255, 0.03) 70%,
			transparent
		);
		transform: rotate(25deg) translateY(-80%);
		transition: transform 0.8s ease;
		pointer-events: none;
	}

	.glass-card:hover::before {
		transform: rotate(25deg) translateY(80%);
	}

	.glass-card:hover {
		border-color: var(--border-glass-hover);
		box-shadow: var(--shadow-glass), var(--shadow-glow);
		transform: translateY(-4px);
	}

	.text-gradient {
		background: linear-gradient(135deg, #ffffff 20%, var(--primary-cyan) 80%, #22d3ee 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.font-display { font-family: var(--font-display); }

	/* Fluid background blobs */
	.fluid-background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		overflow: hidden;
		pointer-events: none;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.35;
		mix-blend-mode: screen;
		animation: float-blob 20s infinite alternate ease-in-out;
	}

	.blob-1 {
		top: -10%;
		left: 10%;
		width: 450px;
		height: 450px;
		background: radial-gradient(circle, rgba(103, 232, 249, 0.35) 0%, transparent 70%);
	}

	.blob-2 {
		bottom: 10%;
		right: -5%;
		width: 500px;
		height: 500px;
		background: radial-gradient(circle, rgba(34, 211, 238, 0.3) 0%, transparent 70%);
		animation-delay: -5s;
		animation-duration: 25s;
	}

	.blob-3 {
		top: 40%;
		left: 50%;
		width: 350px;
		height: 350px;
		background: radial-gradient(circle, rgba(103, 232, 249, 0.2) 0%, transparent 70%);
		animation-delay: -10s;
	}

	@keyframes float-blob {
		0% { transform: translate(0, 0) scale(1); }
		50% { transform: translate(50px, -60px) scale(1.1); }
		100% { transform: translate(-30px, 40px) scale(0.95); }
	}

	/* Navigation Bar */
	.navbar {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 100;
		background: rgba(7, 11, 19, 0.45);
		backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-glass);
		transition: var(--transition-smooth);
	}

	.navbar-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 1.25rem 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.logo {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.35rem;
		color: var(--text-primary);
		letter-spacing: 1px;
	}

	.text-accent { color: var(--primary-cyan); }

	.nav-links {
		display: flex;
		gap: 2rem;
	}

	.nav-link {
		color: var(--text-secondary);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: var(--transition-smooth);
	}

	.nav-link:hover {
		color: var(--primary-cyan);
		text-shadow: 0 0 10px rgba(103, 232, 249, 0.35);
	}

	.mobile-menu-btn {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
		z-index: 101;
	}

	.mobile-menu-btn span {
		display: block;
		width: 24px;
		height: 2px;
		background-color: var(--text-primary);
		transition: var(--transition-smooth);
	}

	/* Buttons */
	.btn {
		font-family: var(--font-sans);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		font-weight: 600;
		padding: 0.65rem 1.35rem;
		border-radius: 12px;
		cursor: pointer;
		transition: var(--transition-smooth);
		text-decoration: none;
		border: 1px solid transparent;
		font-size: 0.9rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--primary-cyan) 0%, var(--primary-blue) 100%);
		color: white;
		box-shadow: 0 4px 15px rgba(103, 232, 249, 0.2);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 20px rgba(103, 232, 249, 0.35);
	}

	.btn-glass {
		background: rgba(255, 255, 255, 0.05);
		border-color: rgba(255, 255, 255, 0.15);
		backdrop-filter: blur(8px);
	}

	.btn-glass:hover {
		background: rgba(103, 232, 249, 0.15);
		border-color: var(--primary-cyan);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		color: var(--text-primary);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		border-color: rgba(255, 255, 255, 0.18);
	}

	.btn-lg {
		padding: 0.95rem 1.85rem;
		font-size: 1rem;
		border-radius: 14px;
	}

	/* Content wrapper */
	.content-wrapper {
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		flex-grow: 1;
	}

	/* Hero badge */
	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1.15rem;
		border-radius: 30px;
		font-size: 0.85rem;
		font-weight: 500;
		color: var(--primary-cyan);
		margin-bottom: 2rem;
		background: rgba(13, 20, 38, 0.35);
	}

	.pulse-dot {
		width: 8px;
		height: 8px;
		background-color: var(--primary-cyan);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--primary-cyan);
		animation: pulse 1.5s infinite;
	}

	@keyframes pulse {
		0% { transform: scale(0.9); opacity: 0.6; }
		50% { transform: scale(1.25); opacity: 1; }
		100% { transform: scale(0.9); opacity: 0.6; }
	}

	/* Hero title & subtitle */
	.hero-title {
		font-family: var(--font-display);
		font-size: 4rem;
		font-weight: 700;
		line-height: 1.15;
		margin-bottom: 1.5rem;
		letter-spacing: -1px;
	}

	.hero-subtitle {
		font-size: 1.15rem;
		color: var(--text-secondary);
		max-width: 700px;
		margin: 0 auto 2.5rem auto;
		line-height: 1.6;
	}

	/* Section header */
	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-tag {
		font-size: 0.8rem;
		color: var(--primary-cyan);
		letter-spacing: 2px;
		font-weight: 600;
		text-transform: uppercase;
		display: inline-block;
		margin-bottom: 0.75rem;
	}

	.section-title {
		font-family: var(--font-display);
		font-size: 2.5rem;
		font-weight: 700;
		margin-bottom: 1rem;
	}

	.section-description {
		font-size: 1.05rem;
		color: var(--text-secondary);
		max-width: 600px;
		margin: 0 auto;
		line-height: 1.5;
	}

	/* Footer */
	.footer {
		margin-top: auto;
		border-top: 1px solid var(--border-glass);
		background: rgba(7, 11, 19, 0.8);
		backdrop-filter: blur(8px);
	}

	.footer-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.footer-copy {
		color: var(--text-muted);
		font-size: 0.85rem;
	}

	.footer-links {
		display: flex;
		gap: 1.5rem;
	}

	.footer-link {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.85rem;
		transition: var(--transition-smooth);
	}

	.footer-link:hover {
		color: var(--primary-cyan);
	}

	/* Form inputs */
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.form-label {
		font-size: 0.85rem;
		font-weight: 600;
		color: var(--text-secondary);
	}

	.form-input {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid var(--border-glass);
		border-radius: 10px;
		padding: 0.75rem 1rem;
		color: var(--text-primary);
		font-family: var(--font-sans);
		font-size: 0.95rem;
		outline: none;
		transition: var(--transition-smooth);
		width: 100%;
	}

	.form-input:focus {
		border-color: var(--primary-cyan);
		box-shadow: 0 0 10px rgba(103, 232, 249, 0.15);
		background: rgba(255, 255, 255, 0.05);
	}

	select.form-input option {
		background: var(--bg-dark);
		color: var(--text-primary);
	}

	/* Responsive: navbar collapse */
	@media (max-width: 992px) {
		.nav-links {
			display: none;
		}
		.navbar-container {
			padding: 1rem 1.5rem;
		}
		.mobile-menu-btn {
			display: flex;
		}
	}

	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}
		.hero-subtitle {
			font-size: 1rem;
		}
		.footer-container {
			flex-direction: column;
			text-align: center;
		}
	}
</style>
